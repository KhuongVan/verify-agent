# M1 chạy được KHÔNG cần biến nào (tự sinh khoá, lưu .data/).
# Các biến dưới là cho production (M2+):

# --- Khoá ký số (thay cho .data/signing-key.json khi lên production) ---
# Sinh bằng: openssl genpkey -algorithm ed25519 -out priv.pem ; openssl pkey -in priv.pem -pubout -out pub.pem
# SIGNING_PRIVATE_KEY_PEM="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
# SIGNING_PUBLIC_KEY_PEM="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
# SIGNING_KEY_ID="prod-2026-01"

# --- M2/M3 (chưa dùng ở M1) ---
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=
# MUX_TOKEN_ID=
# MUX_TOKEN_SECRET=
